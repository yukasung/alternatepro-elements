<?xml version="1.0"?>
<ruleset name="AlternatePro Elements">
	<description>Elementor extension plugin for WordPress.</description>

	<!-- Project metadata. -->
	<config name="project_name" value="AlternatePro Elements"/>
	<config name="testVersion" value="8.1-"/>

	<!-- Scan targets. -->
	<file>alternatepro-elements.php</file>
	<file>includes/</file>
	<file>assets/</file>

	<!-- Output and scan behavior. -->
	<arg name="basepath" value="."/>
	<arg name="colors"/>
	<arg name="extensions" value="php,js,css"/>
	<arg name="parallel" value="8"/>

	<!-- Ignore third-party, generated, documentation, language, and build artifacts. -->
	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>docs/*</exclude-pattern>
	<exclude-pattern>*/docs/*</exclude-pattern>
	<exclude-pattern>languages/*</exclude-pattern>
	<exclude-pattern>*/languages/*</exclude-pattern>
	<exclude-pattern>dist/*</exclude-pattern>
	<exclude-pattern>*/dist/*</exclude-pattern>
	<exclude-pattern>build/*</exclude-pattern>
	<exclude-pattern>*/build/*</exclude-pattern>
	<exclude-pattern>coverage/*</exclude-pattern>
	<exclude-pattern>*/coverage/*</exclude-pattern>
	<exclude-pattern>*.min.js</exclude-pattern>
	<exclude-pattern>*.min.css</exclude-pattern>

	<!-- WordPress Coding Standards. -->
	<rule ref="WordPress-Core"/>
	<rule ref="WordPress-Docs"/>
	<rule ref="WordPress-Extra"/>

	<!--
		AlternatePro Elements intentionally uses namespaced PSR-4 class files.
		Keep WordPress standards enabled, but do not enforce legacy class-* file naming.
	-->
	<rule ref="WordPress.Files.FileName.InvalidClassFileName">
		<severity>0</severity>
	</rule>
	<rule ref="WordPress.Files.FileName.NotHyphenatedLowercase">
		<severity>0</severity>
	</rule>

	<!-- PHP 8.1+ compatibility checks for WordPress projects. -->
	<rule ref="PHPCompatibilityWP"/>

	<!-- Project text domain for WordPress i18n checks. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="alternatepro-elements"/>
			</property>
		</properties>
	</rule>
</ruleset>
